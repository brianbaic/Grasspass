# ── GrassPass Environment Configuration ──
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Optional: Mapbox (location autocomplete) ──
# Get a free token at https://account.mapbox.com/
# If omitted, the app falls back to Open-Meteo geocoding for location search.
MAPBOX_ACCESS_TOKEN=

# ── Optional: Rachio (irrigation schedule sync) ──
# Get your API key from https://app.rach.io/ → Account Settings → Get API Key
# If omitted, Rachio sync is disabled; watering events can still be added manually.
RACHIO_API_KEY=

# ── Optional: Server port (default 3000) ──
# PORT=3000
